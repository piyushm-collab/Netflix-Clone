# Custom Backend (no external services needed)
# Backend runs on port 3001 — start with: node server/index.js
VITE_API_URL=http://localhost:3001

# JWT Secret for backend (set in your shell or .env)
JWT_SECRET=netflix-dev-secret-change-in-prod

# TMDb API Configuration (for movie data)
VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_USERNAME=your_tmdb_username
VITE_TMDB_PASSWORD=your_tmdb_password
